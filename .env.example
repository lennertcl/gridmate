# GridMate environment configuration.
# Copy this file to .env and fill in your values.

# ── Local development ────────────────────────────────────────────────────────
LOCAL_DEV=true
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# ── Debug CLI ────────────────────────────────────────────────────────────────
GRIDMATE_APP_URL=http://127.0.0.1:8000
GRIDMATE_APP_HOST=127.0.0.1
GRIDMATE_APP_PORT=8000
GRIDMATE_ADDON_SLUG=gridmate
GRIDMATE_DEBUG_STATE_DIR=.gm

# ── Deploy (used by deploy.sh) ──────────────────────────────────────────────

# IP address or hostname of your Home Assistant instance (required)
HA_HOST=homeassistant.local

# Samba share name (the Samba share addon exposes several shares)
HA_SMB_SHARE=addons

# Folder name inside the share where the addon will be placed
HA_ADDON_FOLDER=gridmate

# Samba credentials (leave empty for guest access)
HA_SMB_USER=
HA_SMB_PASS=
